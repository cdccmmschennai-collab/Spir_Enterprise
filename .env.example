# Application
APP_NAME="SPIR Dynamic Extraction"
APP_VERSION="0.1.0"
DEBUG=false
LOG_LEVEL=INFO

# File handling
MAX_FILE_SIZE_MB=2048
PREVIEW_ROW_COUNT=12

# CORS — must list exact frontend origin (no wildcard) when allow_credentials=True
ALLOWED_ORIGINS=["http://localhost:3000"]

# Auth
APP_USER=admin
APP_PASS=admin123
# Generate with: openssl rand -hex 32
SECRET_KEY=mysecretkey123456
TOKEN_EXPIRE_HOURS=8
